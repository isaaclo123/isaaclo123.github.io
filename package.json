{
  "name": "isaaclo123_website",
  "version": "1.0.0",
  "description": "Website for Isaac Lo",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config webpack.config.js --mode production",
    "start": "webpack serve --config webpack.config.js --mode development",
    "build:sass": "sass --quiet-deps --silence-deprecation=import,slash-div --load-path=src src/sass/style.scss public/style.css",
    "watch:sass": "sass --watch --quiet-deps --silence-deprecation=import,slash-div --load-path=src src/sass/style.scss public/style.css"
  },
  "author": "Isaac Lo",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "sass": "^1.86.3",
    "sass-loader": "^16.0.5",
    "webpack": "^5.99.6",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "font-awesome": "^4.7.0"
  },
  "browserslist": [
    "> 0.1%",
    "Firefox ESR",
    "IE 10"
  ]
}
